<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>BUPT International School Teaching Assistant Recruitment System</display-name>

    <listener>
        <listener-class>com.bupt.tarecruitment.listener.DataBootstrapListener</listener-class>
    </listener>

    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.bupt.tarecruitment.servlet.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.bupt.tarecruitment.servlet.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>DashboardServlet</servlet-name>
        <servlet-class>com.bupt.tarecruitment.servlet.DashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DashboardServlet</servlet-name>
        <url-pattern>/dashboard</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ApplicantProfileServlet</servlet-name>
        <servlet-class>com.bupt.tarecruitment.servlet.ApplicantProfileServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ApplicantProfileServlet</servlet-name>
        <url-pattern>/applicant/profile</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>JobListServlet</servlet-name>
        <servlet-class>com.bupt.tarecruitment.servlet.JobListServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>JobListServlet</servlet-name>
        <url-pattern>/jobs</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>JobDetailServlet</servlet-name>
        <servlet-class>com.bupt.tarecruitment.servlet.JobDetailServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>JobDetailServlet</servlet-name>
        <url-pattern>/jobs/detail</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ApplyJobServlet</servlet-name>
        <servlet-class>com.bupt.tarecruitment.servlet.ApplyJobServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ApplyJobServlet</servlet-name>
        <url-pattern>/jobs/apply</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>MyApplicationsServlet</servlet-name>
        <servlet-class>com.bupt.tarecruitment.servlet.MyApplicationsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>MyApplicationsServlet</servlet-name>
        <url-pattern>/applicant/applications</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>MOJobsServlet</servlet-name>
        <servlet-class>com.bupt.tarecruitment.servlet.MOJobsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>MOJobsServlet</servlet-name>
        <url-pattern>/mo/jobs</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>JobCreateServlet</servlet-name>
        <servlet-class>com.bupt.tarecruitment.servlet.JobCreateServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>JobCreateServlet</servlet-name>
        <url-pattern>/mo/jobs/create</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>MOApplicationsServlet</servlet-name>
        <servlet-class>com.bupt.tarecruitment.servlet.MOApplicationsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>MOApplicationsServlet</servlet-name>
        <url-pattern>/mo/applications</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>UpdateApplicationStatusServlet</servlet-name>
        <servlet-class>com.bupt.tarecruitment.servlet.UpdateApplicationStatusServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UpdateApplicationStatusServlet</servlet-name>
        <url-pattern>/mo/application/update</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AdminWorkloadServlet</servlet-name>
        <servlet-class>com.bupt.tarecruitment.servlet.AdminWorkloadServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminWorkloadServlet</servlet-name>
        <url-pattern>/admin/workload</url-pattern>
    </servlet-mapping>

    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>
</web-app>
